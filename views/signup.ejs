<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #c084fc, #e9d5ff); /* lavender */
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-container {
            background: #ffffff;
            padding: 35px 45px;
            border-radius: 14px;
            box-shadow: 0 10px 30px rgba(128, 90, 213, 0.25);
            width: 320px;
            text-align: center;
        }

        h1 {
            margin-bottom: 25px;
            color: #6b21a8;
        }

        label {
            display: block;
            text-align: left;
            margin-bottom: 6px;
            font-weight: bold;
            color: #5b21b6;
        }

        input {
            width: 100%;
            padding: 11px;
            margin-bottom: 18px;
            border-radius: 8px;
            border: 1px solid #ddd;
            outline: none;
            transition: 0.3s;
        }

        input:focus {
            border-color: #a855f7;
            box-shadow: 0 0 6px rgba(168, 85, 247, 0.4);
        }

        button {
            width: 100%;
            padding: 11px;
            background: #a855f7;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: #9333ea;
        }

        .extra-text {
            margin-top: 15px;
            font-size: 14px;
            color: #555;
        }

        .extra-text a {
            color: #9333ea;
            text-decoration: none;
            font-weight: bold;
        }

        .extra-text a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="login-container">
        <h1>LOGIN</h1>

        <form action="/user/login" method="POST">
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" placeholder="Enter username">

            <label for="password">Password:</label>
            <input type="password" id="password" name="password" placeholder="Enter password">

            <button type="submit">Submit</button>
        </form>

        <div class="extra-text">
            Don’t have an account? <a href="/signup">Sign up</a>
        </div>
    </div>

</body>
</html>